/* pages/record/record.wxss */

.record-page {
  background: #f5f5f5;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ====== 顶部导航 ====== */
.record-header {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx 24rpx;
  background: #ffffff;
  border-bottom: 2rpx solid #e8e8e8;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #222222;
  border: none;
  background: none;
  padding: 0;
  margin: 0;
  line-height: 1;
}

.back-btn::after {
  display: none;
}

.record-header-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
}

.record-header-action {
  width: 72rpx;
  font-size: 24rpx;
  color: #888888;
  text-align: right;
}

/* ====== 进度条 ====== */
.progress-bar {
  display: flex;
  gap: 8rpx;
  padding: 24rpx 32rpx 0;
  background: #ffffff;
}

.progress-step {
  flex: 1;
  height: 8rpx;
  border-radius: 4rpx;
  background: #e8e8e8;
}

.progress-step.done {
  background: #555555;
}

.progress-step.current {
  background: #555555;
  opacity: 0.5;
}

.progress-label {
  font-size: 22rpx;
  color: #888888;
  padding: 8rpx 32rpx 16rpx;
  background: #ffffff;
  text-align: right;
}

/* ====== 表单内容区 ====== */
.record-body {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

.step-content {
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.step-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  letter-spacing: -0.01em;
}

.step-desc {
  font-size: 26rpx;
  color: #888888;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

/* ====== 心情选择 ====== */
.mood-chip-group {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.mood-chip {
  padding: 16rpx 28rpx;
  border: 2rpx solid #d0d0d0;
  border-radius: 40rpx;
  font-size: 26rpx;
  background: #ffffff;
}

.mood-chip.selected {
  border-color: #555555;
  background: #e0e0e0;
}

/* ====== 分类选择 ====== */
.category-chip-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  border: 2rpx solid #d0d0d0;
  border-radius: 40rpx;
  font-size: 24rpx;
  background: #ffffff;
}

.category-chip.selected {
  border-color: #555555;
  background: #e0e0e0;
}

.category-chip-icon {
  font-size: 26rpx;
}

/* ====== 选项列表 ====== */
.option-list {
  margin-bottom: 20rpx;
}

.option-card {
  background: #ffffff;
  border: 2rpx solid #d0d0d0;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.option-letter {
  font-size: 24rpx;
  font-weight: 700;
  color: #888888;
  min-width: 40rpx;
}

.option-input {
  flex: 1;
  border: none;
  font-size: 28rpx;
  background: transparent;
  color: #222222;
  padding: 0;
}

.add-option-btn {
  width: 100%;
  padding: 24rpx;
  border: 2rpx dashed #d0d0d0;
  border-radius: 24rpx;
  background: transparent;
  font-size: 26rpx;
  color: #888888;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.add-option-icon {
  font-size: 32rpx;
}

/* ====== 选择方案（单选列表） ====== */
.choice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.choice-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #d0d0d0;
  border-radius: 16rpx;
  background: #ffffff;
}

.choice-item.selected {
  border-color: #555555;
  background: #e0e0e0;
}

.choice-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #d0d0d0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.choice-item.selected .choice-radio {
  border-color: #555555;
}

.choice-radio-inner {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #555555;
}

.choice-letter {
  font-size: 24rpx;
  font-weight: 700;
  color: #888888;
  min-width: 32rpx;
}

.choice-text {
  flex: 1;
  font-size: 28rpx;
  color: #222222;
}

/* ====== 复盘时间选择 ====== */
.time-chip-grid {
  display: flex;
  gap: 20rpx;
}

.time-chip {
  flex: 1;
  padding: 28rpx 16rpx;
  border: 2rpx solid #d0d0d0;
  border-radius: 24rpx;
  text-align: center;
  background: #ffffff;
}

.time-chip.selected {
  border-color: #555555;
  background: #e0e0e0;
}

.time-chip-value {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
  display: block;
}

.time-chip-label {
  font-size: 22rpx;
  color: #888888;
  display: block;
}

.date-picker-input {
  display: flex;
  align-items: center;
}

.placeholder-text {
  color: #b0b0b0;
  font-size: 26rpx;
}

/* ====== 决策摘要 ====== */
.review-summary {
  background: #ffffff;
  border: 2rpx solid #d0d0d0;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-top: 16rpx;
}

.review-summary-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #e8e8e8;
}

.review-summary-item {
  display: flex;
  padding: 8rpx 0;
  font-size: 26rpx;
}

.review-summary-label {
  color: #888888;
  min-width: 80rpx;
}

.review-summary-value {
  color: #222222;
  flex: 1;
}
