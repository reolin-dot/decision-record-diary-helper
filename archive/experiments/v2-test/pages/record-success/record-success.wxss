/* pages/record-success/record-success.wxss */

.success-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 80rpx 48rpx;
  text-align: center;
  background: linear-gradient(180deg, #e8f0e8 0%, #d4e4d0 50%, #c8dcc4 100%);
}

.success-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx dashed #d0d0d0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  margin-bottom: 40rpx;
  background: rgba(255,255,255,0.5);
}

.success-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.success-desc {
  font-size: 26rpx;
  color: #888888;
  line-height: 1.6;
  margin-bottom: 64rpx;
}
