/* app.wxss - 全局样式 */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  background: #f5f5f5;
  color: #222222;
  font-size: 28rpx;
  line-height: 1.5;

  /* ====== Design Tokens (CSS 变量) ====== */
  --color-bg: #f5f5f5;
  --color-surface: #ffffff;
  --color-border: #e8e8e8;
  --color-border-light: #f0f0f0;
  --color-text-primary: #222222;
  --color-text-secondary: #888888;
  --color-text-placeholder: #b0b0b0;
  --color-accent: #4a7c59;
  --color-accent-light: #e8f0e8;
  --color-accent-dark: #3a6247;
  --color-danger: #c0392b;
  --color-warning: #e67e22;
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
}

/* ====== 通用页面容器 ====== */
.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* ====== 通用按钮 ====== */
.btn-primary {
  width: 100%;
  padding: 28rpx;
  border: none;
  border-radius: var(--radius-md);
  background: var(--color-accent);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-primary[disabled] {
  background: var(--color-border-light);
  color: var(--color-text-placeholder);
}

.btn-secondary {
  width: 100%;
  padding: 28rpx;
  border: 2rpx solid #d0d0d0;
  border-radius: 24rpx;
  background: #ffffff;
  color: #222222;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.btn-secondary:active {
  opacity: 0.8;
}

/* ====== 底部操作栏 ====== */
.bottom-bar {
  padding: 24rpx 32rpx 56rpx;
  background: #ffffff;
  border-top: 2rpx solid #e8e8e8;
}

/* ====== 表单通用样式 ====== */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.form-label .required {
  color: #555555;
  font-size: 24rpx;
}

.form-label .optional {
  color: #b0b0b0;
  font-weight: 400;
  font-size: 22rpx;
}

.form-input {
  width: 100%;
  padding: 24rpx 28rpx;
  border: 2rpx solid #d0d0d0;
  border-radius: 16rpx;
  font-size: 28rpx;
  background: #ffffff;
  color: #222222;
}

.form-textarea {
  min-height: 160rpx;
  line-height: 1.5;
}

.form-hint {
  font-size: 22rpx;
  color: #b0b0b0;
  margin-top: 8rpx;
}

/* ====== 跳过链接 ====== */
.skip-link {
  text-align: center;
  font-size: 26rpx;
  color: #888888;
  padding: 16rpx;
  margin-top: 8rpx;
}
