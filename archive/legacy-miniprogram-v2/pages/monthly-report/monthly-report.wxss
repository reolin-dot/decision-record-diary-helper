/* pages/monthly-report/monthly-report.wxss */

.report-page {
  background: #f0f4f8;
  min-height: 100vh;
  padding-bottom: 48rpx;
}

/* ====== 月份选择器 ====== */
.month-selector {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.month-chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background: #ffffff;
  border: 2rpx solid #d0d0d0;
  font-size: 26rpx;
  color: #666666;
  flex-shrink: 0;
}

.month-chip.active {
  background: #333333;
  color: #ffffff;
  border-color: #333333;
}

/* ====== 空状态 ====== */
.report-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
}

/* ====== 月度总结卡片 ====== */
.report-hero {
  margin: 24rpx 32rpx;
  padding: 48rpx 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 32rpx;
  color: #ffffff;
}

.hero-month {
  font-size: 28rpx;
  opacity: 0.8;
  margin-bottom: 8rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.hero-summary {
  font-size: 28rpx;
  line-height: 1.7;
  opacity: 0.95;
}

/* ====== 通用分区 ====== */
.report-section {
  margin: 24rpx 32rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #888888;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 24rpx;
  display: block;
}

/* ====== 阶段统计 ====== */
.stage-grid {
  display: flex;
  justify-content: space-around;
}

.stage-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stage-icon {
  font-size: 44rpx;
}

.stage-count {
  font-size: 36rpx;
  font-weight: 700;
}

.stage-label {
  font-size: 22rpx;
  color: #888888;
}

/* ====== 分类分布 ====== */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.category-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.category-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  width: 160rpx;
  flex-shrink: 0;
}

.category-icon {
  font-size: 28rpx;
}

.category-label {
  font-size: 26rpx;
}

.category-bar-wrap {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.category-bar {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.category-count {
  font-size: 24rpx;
  color: #888888;
  width: 80rpx;
  text-align: right;
  flex-shrink: 0;
}

/* ====== 情绪标签 ====== */
.mood-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.mood-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #f8f9fa;
  border-radius: 24rpx;
  border: 2rpx solid #e8e8e8;
}

.mood-name {
  font-size: 26rpx;
}

.mood-count {
  font-size: 22rpx;
  color: #888888;
  background: #e8e8e8;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
}

/* ====== 复盘统计 ====== */
.review-stats {
  display: flex;
  gap: 24rpx;
}

.review-stat {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.review-value {
  font-size: 44rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.review-label {
  font-size: 22rpx;
  color: #888888;
  display: block;
}

/* ====== 洞察卡片 ====== */
.insight-cards {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.insight-card {
  padding: 24rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #e8ecf1 100%);
  border-radius: 16rpx;
  border-left: 6rpx solid #667eea;
}

.insight-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #444444;
}

/* ====== 成长片段 ====== */
.snippet-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.snippet-item {
  padding: 24rpx;
  background: #fafafa;
  border-radius: 16rpx;
  border: 2rpx solid #f0f0f0;
}

.snippet-quote {
  font-size: 30rpx;
  font-style: italic;
  line-height: 1.6;
  color: #333333;
  margin-bottom: 16rpx;
}

.snippet-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.snippet-source {
  font-size: 24rpx;
  color: #888888;
}

.snippet-date {
  font-size: 22rpx;
  color: #bbbbbb;
}

/* ====== 操作按钮 ====== */
.report-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin: 32rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.share-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
}

.garden-btn {
  background: #ffffff;
  color: #333333;
  border: 2rpx solid #d0d0d0;
}
