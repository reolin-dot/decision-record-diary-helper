/* pages/watering/watering.wxss */

.page-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.watering-body {
  padding: 32rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #888888;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

/* ====== 复盘列表 ====== */
.review-item {
  background: #ffffff;
  border: 2rpx solid #d0d0d0;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.review-item:active {
  background: #e0e0e0;
}

.review-item-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  display: block;
}

.review-item-meta {
  font-size: 22rpx;
  color: #888888;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.review-item-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  border: 2rpx solid #d0d0d0;
  background: #f5f5f5;
}

/* ====== 空状态 ====== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 80rpx;
  text-align: center;
  color: #888888;
  font-size: 28rpx;
}

/* ====== 浇水元信息 ====== */
.review-item-meta {
  font-size: 22rpx;
  color: #888888;
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.review-item-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  border: 2rpx solid #d0d0d0;
  background: #f5f5f5;
}

.status-text {
  color: #555555;
}

.remaining-text {
  color: #0f6e56;
  font-weight: 500;
}
