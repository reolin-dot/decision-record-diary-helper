/* pages/theme-garden/theme-garden.wxss */

.theme-page {
  background: #f0f4f8;
  min-height: 100vh;
  padding-bottom: 48rpx;
}

/* ====== 空状态 ====== */
.theme-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.theme-empty .empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.theme-empty .empty-text {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.theme-empty .empty-hint {
  font-size: 26rpx;
  color: #999999;
}

/* ====== 主题标签栏 ====== */
.garden-tabs {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  background: #ffffff;
  border: 2rpx solid #e0e0e0;
  border-radius: 32rpx;
  flex-shrink: 0;
}

.tab-item.active {
  background: #333333;
  border-color: #333333;
  color: #ffffff;
}

.tab-icon {
  font-size: 28rpx;
}

.tab-label {
  font-size: 26rpx;
}

.tab-count {
  font-size: 22rpx;
  background: rgba(0, 0, 0, 0.08);
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
}

.tab-item.active .tab-count {
  background: rgba(255, 255, 255, 0.25);
}

/* ====== 概要统计 ====== */
.summary-bar {
  display: flex;
  justify-content: space-around;
  margin: 0 32rpx 24rpx;
  padding: 24rpx 32rpx;
  background: #ffffff;
  border-radius: 20rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.summary-value {
  font-size: 40rpx;
  font-weight: 700;
}

.summary-label {
  font-size: 22rpx;
  color: #888888;
}

/* ====== 决策卡片列表 ====== */
.decision-list {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.decision-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  border: 2rpx solid #f0f0f0;
}

.card-left {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f8f9fa;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.card-stage-icon {
  font-size: 36rpx;
}

.card-body {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  display: flex;
  gap: 16rpx;
}

.card-stage-label {
  font-size: 22rpx;
  color: #888888;
  background: #f0f0f0;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.card-time {
  font-size: 22rpx;
  color: #bbbbbb;
}

.card-arrow {
  color: #cccccc;
  font-size: 36rpx;
  flex-shrink: 0;
}
