/* pages/coach-result/coach-result.wxss */

.result-body {
  padding: 32rpx;
  padding-bottom: 160rpx;
}

.result-card {
  background: #ffffff;
  border: 2rpx solid #e8e8e8;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
}

.result-card-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 24rpx;
  text-align: center;
}

.result-comparison {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.result-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
}

.result-col-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #222222;
  margin-bottom: 8rpx;
  text-align: center;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #e8e8e8;
}

.result-item {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: #888888;
  padding: 8rpx 0;
}

.result-item.pro {
  color: #2e7d32;
}

.result-item.con {
  color: #c62828;
}

.result-score {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #e8e8e8;
  text-align: center;
}

.result-score .score-label {
  display: block;
  font-size: 26rpx;
  color: #888888;
  margin-bottom: 16rpx;
}

.score-values {
  display: flex;
  gap: 24rpx;
}

.score-item {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #222222;
}

.score-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #555555;
}

.disclaimer {
  background: #ffffff;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 24rpx;
  color: #888888;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.save-draft-btn {
  width: 100%;
  padding: 28rpx;
  border: 2rpx dashed #d0d0d0;
  border-radius: 24rpx;
  background: transparent;
  color: #888888;
  font-size: 28rpx;
  text-align: center;
  line-height: 1.4;
}

.save-draft-btn::after {
  border: none;
}
