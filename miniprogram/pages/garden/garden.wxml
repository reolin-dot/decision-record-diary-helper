<!-- pages/garden/garden.wxml -->
<view class="garden-page">
  <view class="garden-top-bar" style="padding-top: {{statusBarHeight + 10}}px;">
    <view class="garden-user-info">
      <view class="garden-avatar" bindtap="onGoProfile"><text>👤</text></view>
      <view class="garden-streak" wx:if="{{!isEmpty}}">
        <text>🔥 连续 <text class="streak-num">{{stats.streak}}</text> 天记录</text>
      </view>
      <view class="garden-streak" wx:else>
        <text>欢迎来到决策花园</text>
      </view>
    </view>
  </view>

  <!-- ====== 新用户引导 ====== -->
  <view class="garden-scene" wx:if="{{isNewUser}}">
    <view class="empty-garden">
      <view class="empty-illustration">
        <text class="empty-icon-large">🌱</text>
        <view class="empty-ground"></view>
      </view>
      <view class="empty-text-group">
        <text class="empty-title">欢迎来到你的决策花园</text>
        <text class="empty-desc">每一个重要决策，都是一颗种子。</text>
        <text class="empty-desc">记录下来，开始行动，再慢慢复盘，</text>
        <text class="empty-desc">它会陪你从种子长到盛开。</text>
      </view>
      <view class="empty-steps">
        <view class="empty-step">
          <text class="step-num">1</text>
          <text class="step-text">种花 — 看清问题并做选择</text>
        </view>
        <view class="empty-step">
          <text class="step-num">2</text>
          <text class="step-text">长叶 — 开始推进真实行动</text>
        </view>
        <view class="empty-step">
          <text class="step-num">3</text>
          <text class="step-text">开花 — 当下复盘和结果复盘</text>
        </view>
      </view>
      <view class="empty-cta" bindtap="onPlantFlower">
        <text>种下第一颗种子</text>
      </view>
    </view>
  </view>

  <!-- ====== 空花园（非新用户但无决策） ====== -->
  <view class="garden-scene" wx:elif="{{isEmpty}}">
    <view class="empty-garden">
      <view class="empty-illustration">
        <text class="empty-icon-large">🌱</text>
        <view class="empty-ground"></view>
      </view>
      <view class="empty-text-group">
        <text class="empty-title">花园还是空的</text>
        <text class="empty-desc">记录一个决策，种下第一颗种子吧</text>
      </view>
      <view class="empty-cta" bindtap="onPlantFlower">
        <text>种下第一颗种子</text>
      </view>
    </view>
  </view>

  <!-- ====== 有决策时的正常花园 ====== -->
  <view class="garden-scene" wx:else>
    <!-- 花园状态统计 -->
    <view class="garden-stats">
      <view class="garden-stat-item">
        <text class="stat-num">{{stats.growingCount}}</text>
        <text class="stat-label">正在生长</text>
      </view>
      <view class="garden-stat-divider"></view>
      <view class="garden-stat-item">
        <text class="stat-num">{{pendingReviews.length}}</text>
        <text class="stat-label">等待复盘</text>
      </view>
      <view class="garden-stat-divider"></view>
      <view class="garden-stat-item">
        <text class="stat-num">{{stats.bloomedCount}}</text>
        <text class="stat-label">已经盛开</text>
      </view>
    </view>

    <!-- 待复盘温柔提醒 -->
    <view class="garden-reminder" wx:if="{{pendingReviews.length > 0}}" bindtap="onWatering">
      <view class="reminder-dot"></view>
      <text class="reminder-text">{{pendingReviews.length}} 朵花等你回来看看</text>
      <text class="reminder-arrow">›</text>
    </view>

    <!-- 最近成长片段 -->
    <view class="garden-growth-snippet" wx:if="{{latestLesson}}">
      <text class="snippet-label">最近成长片段</text>
      <text class="snippet-text">"{{latestLesson}}"</text>
    </view>

    <!-- 花朵网格 -->
    <view class="flower-grid">
      <view class="flower-card" wx:for="{{flowerGrid}}" wx:key="id" bindtap="onGoDecision" data-id="{{item.id}}">
        <view class="flower-visual stage-{{item.stage}}">
          <text class="flower-emoji">{{item.stageIcon}}</text>
        </view>
        <view class="flower-info">
          <text class="flower-stage-label">{{item.stageLabel}}</text>
          <text class="flower-title">{{item.title}}</text>
        </view>
      </view>
    </view>

    <!-- 本月进度 -->
    <view class="garden-monthly" wx:if="{{stats.monthlyDecisions > 0}}">
      <text>本月种下 {{stats.monthlyDecisions}} 个决策</text>
    </view>
  </view>

  <view class="garden-actions">
    <view class="garden-action-btn" bindtap="onPlantFlower">
      <view class="garden-action-icon"><text>🌱</text></view>
      <view class="garden-action-label"><text>种花</text></view>
      <view class="garden-action-sub"><text>记录新决策</text></view>
    </view>

    <view class="garden-action-btn" bindtap="onWatering">
      <view class="garden-action-icon">
        <text>💧</text>
        <view class="badge" wx:if="{{pendingReviews.length > 0}}">{{pendingReviews.length}}</view>
      </view>
      <view class="garden-action-label"><text>浇水</text></view>
      <view class="garden-action-sub"><text>复盘决策</text></view>
    </view>

    <view class="garden-action-btn" bindtap="onGoCoach">
      <view class="garden-action-icon"><text>🧭</text></view>
      <view class="garden-action-label"><text>锦囊</text></view>
      <view class="garden-action-sub"><text>辅助分析</text></view>
    </view>
  </view>

  <view class="recent-section" wx:if="{{recentDecisions.length > 0}}">
    <text class="recent-title">最近决策</text>
    <view class="recent-list">
      <view class="recent-item" wx:for="{{recentDecisions}}" wx:key="id" bindtap="onGoDecision" data-id="{{item.id}}">
        <text class="recent-stage-icon">{{item.stageIcon}}</text>
        <view class="recent-item-body">
          <text class="recent-item-title">{{item.title}}</text>
          <text class="recent-item-date">{{item.stageLabel}} · {{item.stageDesc}}</text>
        </view>
        <text class="recent-item-arrow">›</text>
      </view>
    </view>
  </view>
</view>
