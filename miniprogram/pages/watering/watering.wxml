<view class="page-container">
  <view class="watering-body">
    <text class="subtitle">这些决策到了复盘时间，花 30 秒回顾一下吧。</text>

    <view class="review-item" wx:for="{{pendingDecisions}}" wx:key="id" bindtap="onGoReview" data-id="{{item.id}}">
      <view class="review-item-body">
        <text class="review-item-title">{{item.title}}</text>
        <view class="review-item-meta">
          <text>{{item.createdAt}} 记录</text>
          <text wx:if="{{item._wateredText}}">{{item._wateredText}}</text>
        </view>
      </view>
      <view class="review-item-status">
        <text class="status-text">待复盘</text>
        <text wx:if="{{item._remainingText}}" class="remaining-text">{{item._remainingText}}</text>
      </view>
    </view>

    <view class="empty-state" wx:if="{{pendingDecisions.length === 0}}">
      <text>暂无待复盘的决策</text>
    </view>
  </view>
</view>
