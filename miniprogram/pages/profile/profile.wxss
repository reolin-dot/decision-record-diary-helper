/* pages/profile/profile.wxss */

.profile-page {
  background: #f5f5f5;
  min-height: 100vh;
}

/* ====== 头部区域 ====== */
.profile-header-section {
  background: #ffffff;
  padding: 40rpx 32rpx 48rpx;
  border-bottom: 2rpx solid #e8e8e8;
}

.profile-top {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 32rpx;
}

.profile-avatar-large {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 4rpx solid #d0d0d0;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
  display: block;
}

.profile-style-tag {
  font-size: 24rpx;
  color: #888888;
  background: #f5f5f5;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e8e8e8;
  display: inline-block;
}

/* ====== 统计数据 ====== */
.profile-stats {
  display: flex;
  flex-wrap: wrap;
}

.profile-stat {
  flex: 1 1 50%;
  text-align: center;
  padding: 24rpx 16rpx;
  border-right: 2rpx solid #e8e8e8;
  border-bottom: 2rpx solid #e8e8e8;
}

.profile-stat:nth-child(2n) {
  border-right: none;
}

.profile-stat:nth-last-child(-n+2) {
  border-bottom: none;
}

.profile-stat-value {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
  display: block;
}

.profile-stat-label {
  font-size: 22rpx;
  color: #888888;
  display: block;
}

/* ====== 分区 ====== */
.profile-section {
  padding: 32rpx;
}

.profile-section-title {
  font-size: 22rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: #888888;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

/* ====== 成就徽章 ====== */
.achievement-grid {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.achievement-badge {
  width: calc(33.33% - 14rpx);
  height: 160rpx;
  border: 2rpx solid #d0d0d0;
  border-radius: 24rpx;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-sizing: border-box;
}

.achievement-badge.unlocked {
  border-color: #555555;
  background: #e0e0e0;
}

.badge-icon {
  font-size: 48rpx;
  opacity: 0.4;
}

.achievement-badge.unlocked .badge-icon {
  opacity: 1;
}

.badge-name {
  font-size: 20rpx;
  color: #888888;
  text-align: center;
  line-height: 1.2;
}

/* ====== 设置列表 ====== */
.settings-list {
  background: #ffffff;
  border-radius: 24rpx;
  border: 2rpx solid #d0d0d0;
  overflow: hidden;
}

.settings-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #e8e8e8;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-item-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  border: 2rpx solid #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 24rpx;
  background: #f5f5f5;
}

.settings-item-label {
  flex: 1;
  font-size: 28rpx;
}

.settings-item-arrow {
  color: #b0b0b0;
  font-size: 28rpx;
}

.settings-item.disabled {
  opacity: 0.55;
}

.settings-item-soon {
  font-size: 20rpx;
  color: #ffffff;
  background: #b0b0b0;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
  margin-left: auto;
}

/* ====== 空状态 ====== */
.profile-stats-empty {
  text-align: center;
  padding: 32rpx 0 8rpx;
}

.stats-empty-text {
  font-size: 24rpx;
  color: #b0b0b0;
}
