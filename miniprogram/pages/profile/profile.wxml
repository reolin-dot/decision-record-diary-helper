<view class="profile-page">
  <view class="profile-header-section">
    <view class="profile-top">
      <view class="profile-avatar-large">👤</view>
      <view>
        <text class="profile-name">{{userInfo.name || '决策者'}}</text>
        <text class="profile-style-tag">{{decisionStyle.type || '待测试'}}</text>
      </view>
    </view>
    <view class="profile-stats" wx:if="{{stats.totalDecisions > 0}}">
      <view class="profile-stat">
        <text class="profile-stat-value">{{stats.totalDecisions}}</text>
        <text class="profile-stat-label">总决策数</text>
      </view>
      <view class="profile-stat">
        <text class="profile-stat-value">{{stats.reviewRate}}</text>
        <text class="profile-stat-label">复盘完成率</text>
      </view>
      <view class="profile-stat">
        <text class="profile-stat-value">{{stats.bloomedCount}}</text>
        <text class="profile-stat-label">盛开花朵</text>
      </view>
      <view class="profile-stat">
        <text class="profile-stat-value">{{stats.growthLoopRate || '0%'}}</text>
        <text class="profile-stat-label">成长闭环率</text>
      </view>
    </view>
    <view class="profile-stats-empty" wx:else>
      <text class="stats-empty-text">还没有决策记录哦，去花园种下第一颗种子吧</text>
    </view>
  </view>

  <view class="profile-section">
    <text class="profile-section-title">成就徽章</text>
    <view class="achievement-grid">
      <view class="achievement-badge {{item.unlocked ? 'unlocked' : ''}}" wx:for="{{badges}}" wx:key="name">
        <view class="badge-icon">{{item.icon}}</view>
        <text class="badge-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="profile-section">
    <text class="profile-section-title">设置</text>
    <view class="settings-list">
      <view class="settings-item {{item.disabled ? 'disabled' : ''}}" wx:for="{{settings}}" wx:key="label" bindtap="{{item.disabled ? '' : 'onTapSetting'}}" data-action="{{item.action}}" data-disabled="{{item.disabled}}">
        <text class="settings-item-icon">{{item.icon}}</text>
        <text class="settings-item-label">{{item.label}}</text>
        <text wx:if="{{item.disabled}}" class="settings-item-soon">即将上线</text>
        <text wx:else class="settings-item-arrow">›</text>
      </view>
    </view>
  </view>
</view>
